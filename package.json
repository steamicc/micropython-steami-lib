{
  "name": "micropython-steami-lib",
  "private": true,
  "description": "MicroPython driver library for the STeaMi board.",
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "git-precommit-checks": "^3.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "validate-branch-name": "^1.3.2"
  },
  "lint-staged": {
    "*.py": "ruff check"
  },
  "validate-branch-name": {
    "pattern": "^(main|feat/.*|fix/.*|docs/.*|tooling/.*|ci/.*|test/.*|style/.*)$",
    "errorMsg": "Branch name must match: feat/, fix/, docs/, tooling/, ci/, test/, or style/"
  },
  "git-precommit-checks": {
    "rules": [
      {
        "filter": "\\.(py|yml|yaml|md|toml)$",
        "nonBlocking": "true",
        "message": "You have files with merge conflict markers",
        "regex": "(<<<<<<<|>>>>>>>)"
      },
      {
        "message": "You have files with TODO/FIXME markers",
        "nonBlocking": "true",
        "regex": "(TODO|FIXME)",
        "filter": "\\.py$"
      }
    ]
  }
}
